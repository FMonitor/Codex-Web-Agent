HOST_WORKSPACE_ROOT=/home/monitor
CODEX_CONTAINER_UID=0
CODEX_CONTAINER_GID=0

# Default OpenAI/Codex model used by the openai-login profile
CODEX_DEFAULT_MODEL=gpt-5-codex
CODEX_OPENAI_MODEL=gpt-5-codex

# Custom OpenAI-compatible API provider
# Override for the Codex-facing Responses proxy URL written into the profile
CODEX_CUSTOM_API_COMPAT_BASE_URL=http://codex-responses-proxy:11434/v1
# Port published to the host for /v1/models discovery and local debugging
CODEX_RESPONSES_PROXY_PORT=11434
CODEX_CUSTOM_API_KEY_ENV=CUSTOM_LLM_API_KEY
CUSTOM_LLM_API_KEY=
CODEX_CUSTOM_API_MODEL=gpt-5-codex

# Optional provider that reuses OpenAI login/auth against a proxy
CODEX_CUSTOM_OPENAI_AUTH_BASE_URL=
CODEX_CUSTOM_OPENAI_AUTH_MODEL=gpt-5-codex

# API Compact
# Use host.docker.internal to access services on the host machine
UPSTREAM_BASE_URL=http://host.docker.internal:8002/v1
UPSTREAM_API_KEY=None