# Host path mounted into app and codex containers.
HOST_WORKSPACE_ROOT=/home/monitor

# Build mirrors
NPM_MIRROR=https://registry.npmmirror.com
APT_MIRROR=http://mirrors.aliyun.com/debian
APT_SECURITY_MIRROR=http://mirrors.aliyun.com/debian-security

# App
APP_PORT=8787
DEFAULT_RUNTIME=codex-cli
DEFAULT_WORKSPACE_PATH=/host-workspace
CODEX_CLI_COMMAND=docker exec -i codex-cli-runtime codex
CODEX_MODEL=Qwen3.5-9B-Q5_K_M
CODEX_PROFILE=custom-api
CODEX_SANDBOX=workspace-write

# CodexCLI
CODEX_CONTAINER_UID=0
CODEX_CONTAINER_GID=0
CODEX_DEFAULT_MODEL=Qwen3.5-9B-Q5_K_M
CODEX_OPENAI_MODEL=gpt-5-codex
CODEX_CUSTOM_API_MODEL=Qwen3.5-9B-Q5_K_M
CODEX_CUSTOM_API_BASE_URL=http://api-adapter:11434/v1
CODEX_CUSTOM_API_KEY_ENV=CUSTOM_LLM_API_KEY
CUSTOM_LLM_API_KEY=
CODEX_CUSTOM_OPENAI_AUTH_BASE_URL=
CODEX_CUSTOM_OPENAI_AUTH_MODEL=Qwen3.5-9B-Q5_K_M
OPENAI_API_KEY=

# APIAdapter
API_ADAPTER_PORT=11434
UPSTREAM_BASE_URL=https://gemma4.lcmonitor.dynv6.net:8002/v1
UPSTREAM_API_KEY=
